# ── AUTH ────────────────────────────────────────────────────────
AUTH_USER=admin@fky
AUTH_PASS=kademeliAlımçokönemli!
# En az 32 karakter rastgele string (örn: openssl rand -hex 32)
SESSION_SECRET=

# Fiyat ve topbar için (Yahoo endpointleri)
HOST=127.0.0.1
PORT=3001

# Fundamentals kaynağı: snapshot (önerilen) veya hybrid
FUND_SOURCE=snapshot
# 1=eksik finansal metrikleri istek sırasında senkron tamamla (doğruluk öncelikli)
FUND_SYNC_TOPUP=1
# 0=finansal veride yalnızca KAP kullan (önerilen), 1=Yahoo fundamental fallback aç
FUND_ALLOW_YAHOO_FUND=0
# Finansal metrik modu:
# - kap_truth  : KAP hesapları esas (varsayılan)
# - tv_parity  : TradingView metriklerini birebir yansıt (sapma karşılaştırması için)
FUND_METRIC_MODE=kap_truth
# TV parity cache süresi (ms) ve chunk boyutu
TV_PARITY_CACHE_MS=120000
TV_PARITY_CHUNK_SIZE=50

# Resmi makro kaynakları
# FRED API key zorunlu değildir (CSV endpoint fallback var), ama önerilir.
FRED_API_KEY=

# TCMB EVDS (resmi) key: https://evds2.tcmb.gov.tr/
EVDS_API_KEY=

# EVDS seri kodları (hesabındaki doğru kodlarla doldur)
EVDS_SERIES_USDTRY=TP.DK.USD.S.YTL
EVDS_SERIES_POLICY_RATE=
EVDS_SERIES_CPI=
EVDS_SERIES_GROWTH=
EVDS_SERIES_UNEMP=